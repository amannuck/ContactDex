# Copy to `.env.local` and fill from Botpress Cloud embed snippet:
# NEXT_PUBLIC_BOTPRESS_WEBCHAT_CONFIG={"botId":"...","clientId":"...","configuration":{...}}

# Server-only: Dex-wide flashcards (/flashcards with no ?context=) call Botpress Runtime API,
# then your bot must reply with JSON {"cardIds":["001",...]} (see bot/setup.txt).
# BOTPRESS_PERSONAL_ACCESS_TOKEN=bp_pat_...
# BOTPRESS_BOT_ID=<same as botId in webchat JSON, or set NEXT_PUBLIC_BOTPRESS_BOT_ID>
# BOTPRESS_INTEGRATION_ID=<Webchat integration id from Botpress Cloud>
# BOTPRESS_CHANNEL=web
# Optional: BOTPRESS_FLASHCARD_TRIGGER=__dex_flashcards__   (must match Studio transition)
